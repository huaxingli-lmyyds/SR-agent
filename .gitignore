# -----------------------------------------------------------------------------
# Repository documentation policy
# Keep only repository-level overview documents in version control by default.
# Detailed notes, experiment writeups, and generated reports should stay local
# unless explicitly force-added by maintainers.
# -----------------------------------------------------------------------------
*.md
!/README.md
!/demo/README.md
!/CHANGELOG.md
!/CONTRIBUTING.md
!/LICENSE.md
read/
docs/build/
docs/API/*.rst
/site/

# -----------------------------------------------------------------------------
# Local datasets, downloaded assets, and large archives
# -----------------------------------------------------------------------------
/datasets/
datasets.zip
*.zip
!scripts/*.zip
**/audio_cache/
**/downloads/

# -----------------------------------------------------------------------------
# Experiment outputs, training artifacts, checkpoints, and caches
# -----------------------------------------------------------------------------
agent/experiments/
agent/experiments_*/
agent/experiments_hpo_version*/
agent/results/
agent/logs/
agent/prep_cache/
agent/memory/episodes.jsonl
experiment_archives/
result_of_stage_*/
results/
save/
**/results/
**/save/
**/log/
**/logs/
**/train_log.txt
**/*.log
**/model_checkpoints/
**/pretrained_model_checkpoints/
**/pretrained_models/
*.ckpt
*.pt
*.pth
*.onnx
*.safetensors
scores.txt

# -----------------------------------------------------------------------------
# Temporary files produced by tests, scripts, and local tooling
# -----------------------------------------------------------------------------
.tmp/
tests/tmp/
tests/download/
agent/tests/
agent/test*.py
agent/agents/test*.py
agent/experiment*.zip
configs/*_test.json
configs/*_backup*
*.bak
*.backup
*.orig
*.rej
*~

# -----------------------------------------------------------------------------
# Python bytecode, packaging, and build outputs
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# -----------------------------------------------------------------------------
# Test, coverage, and static-analysis caches
# -----------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
cover/

# -----------------------------------------------------------------------------
# Virtual environments and dependency folders
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/
node_modules/

# -----------------------------------------------------------------------------
# Databases and local application state
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy/
celerybeat-schedule
celerybeat.pid

# -----------------------------------------------------------------------------
# IDE, OS, notebook, and miscellaneous local files
# -----------------------------------------------------------------------------
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject
.ipynb_checkpoints/
profile_default/
ipython_config.py
.DS_Store
Thumbs.db
